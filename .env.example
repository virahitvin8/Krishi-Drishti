# ============================================
# Krishi Drishti - Environment Configuration
# ============================================
# Copy this to .env and fill in your credentials

# --- CDSE (Copernicus Data Space Ecosystem) ---
# Get credentials from: https://dataspace.copernicus.eu/
CDSE_CLIENT_ID=your_cdse_client_id
CDSE_CLIENT_SECRET=your_cdse_client_secret

# --- Supabase Database ---
# Create project at: https://supabase.com/
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# --- USGS EarthExplorer (for Landsat data) ---
# Register at: https://earthexplorer.usgs.gov/
USGS_USERNAME=your_usgs_username
USGS_PASSWORD=your_usgs_password

# --- NASA EarthData ---
# Register at: https://urs.earthdata.nasa.gov/
NASA_EARTHDATA_USER=your_nasa_username
NASA_EARTHDATA_PASS=your_nasa_password

# --- ISRO Bhoonidhi ---
# Register at: https://bhoonidhi.nrsc.gov.in/
BHOONIDHI_USER=your_bhoonidhi_username
BHOONIDHI_PASS=your_bhoonidhi_password

# --- App Settings ---
SATELLITE_REFRESH_DAYS=7
MAX_CSV_UPLOAD_MB=10
