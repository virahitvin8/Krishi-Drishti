# Environment Configuration
# Copy to .env and fill in your credentials

# --- Google Earth Engine (FREE - 17+ data sources) ---
# Register: https://earthengine.google.com/
GEE_SERVICE_ACCOUNT_JSON=

# --- CDSE (Copernicus Data Space Ecosystem) ---
# Free: https://dataspace.copernicus.eu/
CDSE_CLIENT_ID=your_id
CDSE_CLIENT_SECRET=your_secret

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_key

# --- ISRO Bhoonidhi ---
BHOONIDHI_USER=your_username
BHOONIDHI_PASS=your_password

# --- App ---
SATELLITE_REFRESH_DAYS=7
MAX_CSV_UPLOAD_MB=50
